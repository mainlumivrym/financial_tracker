rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can only read/write their own transactions
    match /transactions/{transaction} {
      allow read, write: if request.auth != null 
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.userId;
    }
    
    // Categories: All users can read all categories (default + their own custom)
    // Users can only create/update/delete their own custom categories
    match /categories/{category} {
      // Anyone authenticated can read all categories
      allow read: if request.auth != null;
      
      // Allow creating default categories (no userId field) OR custom categories for the user
      allow create: if request.auth != null && (
        // Default categories don't have a userId field
        (request.resource.data.isDefault == true && !('userId' in request.resource.data))
        ||
        // Custom categories must belong to the authenticated user
        (request.resource.data.userId == request.auth.uid && request.resource.data.isDefault == false)
      );
      
      // Users can update/delete only their own custom categories
      allow update, delete: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && resource.data.isDefault == false;
    }
  }
}
